# Optional public URL used by devices, for example https://sub.example.com
# Leave empty and the admin panel will use the current domain.
PUBLIC_BASE_URL=

# Optional. Leave empty to publish clean subscription URLs without ?token=.
DOWNLOAD_TOKEN=

# Used only when CONVERTER_INPUT=hosted-raw. It lets subconverter read the temporary raw YAML.
RAW_DOWNLOAD_TOKEN=change-me-raw-token

# Admin login for the web UI and API.
ADMIN_TOKEN=change-me-long-random-token

# Subscription URLs, converter URL, and template URL are edited in /subadmin/.

# Provider adapter: manual, generic-playwright, or custom module path such as ./src/provider/my-provider.js
PROVIDER_ADAPTER=manual

# If your provider needs a website click before subscription refresh, use generic-playwright first.
PROVIDER_LOGIN_URL=https://provider.example.com/login
PROVIDER_USERNAME=
PROVIDER_PASSWORD=
PROVIDER_USERNAME_SELECTOR=input[name="email"]
PROVIDER_PASSWORD_SELECTOR=input[name="password"]
PROVIDER_SUBMIT_SELECTOR=button[type="submit"]
# Optional. Use this when the enable button is on another page after login.
PROVIDER_ENABLE_URL=
PROVIDER_ENABLE_SELECTOR=
# Optional fallback when you do not know the CSS selector, for example 开启订阅
PROVIDER_ENABLE_TEXT=
PROVIDER_AFTER_LOGIN_WAIT_MS=1500
PROVIDER_AFTER_ENABLE_WAIT_MS=1500

# Converter mode: remote-subconverter or passthrough
CONVERTER_MODE=remote-subconverter

# hosted-raw mirrors the old workflow: publish configraw.yaml first, then let subconverter read it.
# provider-url sends the provider subscription URL directly to subconverter.
CONVERTER_INPUT=provider-url
SUBCONVERTER_URL=https://sub.dler.io/sub
TARGET=clash
CONFIG_TEMPLATE_URL=
SUBCONVERTER_EXTRA_PARAMS=emoji=true&udp=true&list=false

# Update behavior
UPDATE_TIMEOUT_MS=120000
RAW_USER_AGENT=ClashforWindows/0.20.39
KEEP_BACKUPS=20

# Server
HOST=0.0.0.0
PORT=3000
